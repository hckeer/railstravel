<!-- app/views/home/index.html.erb -->
<% if logged_in? %>
  <div class="user-info">
    <h3>Welcome, <%= current_user.name %></h3>
    <% if current_user.is_a?(Organization) %>
      <p><strong>PAN Card:</strong> <%= current_user.pan_card_number %></p>
      <p><strong>Citizenship:</strong> <%= current_user.citizenship %></p>
      <%= link_to "View Applications", applications_path, class: "btn" %>
    <% end %>
    <p><strong>Email:</strong> <%= current_user.email %></p>
  </div>
<% end %>

<h2>Recent Posts</h2>

<% @posts.each do |post| %>
  <div class="post card">
    <h3 class="post-title"><%= post.title %></h3>
    <div class="post-meta">
      Posted by <%= post.author.name %> on <%= post.created_at.strftime("%B %d, %Y") %>
    </div>
    <div class="post-content">
      <%= post.content %>
    </div>
    
    <% if logged_in? && current_user.is_a?(Client) %>
      <% if current_user.applied_posts.include?(post) %>
        <button class="btn" disabled>Applied</button>
      <% else %>
        <%= button_to "Get Hired", post_applications_path(post), method: :post, class: "btn" %>
      <% end %>
    <% end %>
  </div>
<% end %>