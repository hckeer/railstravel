<!-- app/views/registrations/new.html.erb -->
<div class="card">
  <h2>Sign Up</h2>

  <div style="margin-bottom: 20px;">
    <%= link_to "Sign up as Client", signup_path(type: 'client'), class: "btn" %>
    <%= link_to "Sign up as Organization", signup_path(type: 'organization'), class: "btn" %>
  </div>

  <% if params[:type] == 'organization' %>
    <%= form_with model: @organization || Organization.new, url: signup_path(type: 'organization') do |form| %>
      <div class="form-group">
        <%= form.label :name, "Organization Name" %>
        <%= form.text_field :name, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :email %>
        <%= form.email_field :email, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :password %>
        <%= form.password_field :password, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :pan_card_number, "PAN Card Number" %>
        <%= form.text_field :pan_card_number, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :citizenship, "Citizenship Number" %>
        <%= form.text_field :citizenship, required: true %>
      </div>

      <%= form.submit "Create Organization Account", class: "btn" %>
    <% end %>
  <% else %>
    <%= form_with model: @client || Client.new, url: signup_path do |form| %>
      <div class="form-group">
        <%= form.label :name %>
        <%= form.text_field :name, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :email %>
        <%= form.email_field :email, required: true %>
      </div>

      <div class="form-group">
        <%= form.label :password %>
        <%= form.password_field :password, required: true %>
      </div>

      <%= form.submit "Create Client Account", class: "btn" %>
    <% end %>
  <% end %>

  <p>Already have an account? <%= link_to "Login", login_path %></p>
</div>